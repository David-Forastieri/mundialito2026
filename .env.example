# ── Supabase ──────────────────────────────────────────────────────
# Obtené estos valores en: proyecto → Connect → .env.local
NEXT_PUBLIC_SUPABASE_URL=https://smckwawrclmdqztudnmc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key: Settings → API Keys → secret key (empieza con sb_secret_)
SUPABASE_SECRET_KEY=sb_secret_...

# ── App URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OAuth: Google ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── OAuth: GitHub ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=...

# ── Webhook seguridad ──────────────────────────────────────────────
WEBHOOK_SECRET=cambia-esto-por-un-secreto-seguro

# ── Web Push (Notificaciones) ──────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNtGe8...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@tu-dominio.com

# ── AllSportsAPI (via RapidAPI) ────────────────────────────────────
# Plan Basic gratuito: 100 req/día
# rapidapi.com/allsports/api/allsportsapi2
ALLSPORTS_API_KEY=tu-rapidapi-key-aqui
ALLSPORTS_API_KEY_2=tu-segunda-rapidapi-key-aqui   # opcional — rotación automática en 429
ALLSPORTS_API_HOST=allsportsapi2.p.rapidapi.com

# ── Email (Resend) ─────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
# Sin dominio propio: los emails salen desde onboarding@resend.dev
RESEND_API_KEY=re_...

# ── Vercel Cron ────────────────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=cambia-esto-por-un-secreto-seguro

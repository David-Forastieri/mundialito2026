# ── Supabase ──────────────────────────────────────────────────────
# Obtené estos valores en: proyecto → Connect → .env.local
NEXT_PUBLIC_SUPABASE_URL=https://smckwawrclmdqztudnmc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key: Settings → API Keys → secret key (empieza con sb_secret_)
SUPABASE_SECRET_KEY=sb_secret_...

# ── App URL ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OAuth: Google ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── OAuth: GitHub ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=...

# ── Webhook seguridad ──────────────────────────────────────────────
WEBHOOK_SECRET=cambia-esto-por-un-secreto-seguro

# ── Web Push (Notificaciones) ──────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNtGe8...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:admin@tu-dominio.com

# ── API de Fixture Externo (opcional) ─────────────────────────────
FOOTBALL_API_KEY=tu-api-key-aqui
FOOTBALL_API_URL=https://v3.football.api-sports.io

# ── Vercel Cron ────────────────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=cambia-esto-por-un-secreto-seguro

# ── WC2026 API ─────────────────────────────────────────────────────
# Registrate gratis en: wc2026api.com
# 100 requests/día gratuitos — sin tarjeta de crédito
WC2026_API_KEY=wc2026_your_key_here
WC2026_API_URL=https://api.wc2026api.com
